{
  "name": "@a1liu/js-utils",
  "version": "0.0.4",
  "type": "module",
  "repository": "https://github.com/A1Liu/js-utils",
  "scripts": {
    "format": "prettier --write .",
    "ts-check": "tsc && tsc -p tsconfig.test.json",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./util": "./dist/util.js",
    "./async": "./dist/async.js",
    "./zustand/idb-store": "./dist/zustand/idb-store.js",
    "./form": "./dist/form/index.js",
    "./postgres/queue": "./dist/postgres/queue.js",
    ".": "./dist/index.js"
  },
  "typesVersions": {
    "*": {
      "async": [
        "dist/async.d.ts"
      ],
      "util": [
        "dist/util.d.ts"
      ],
      "form": [
        "dist/form/index.d.ts"
      ],
      "zustand/idb-store": [
        "dist/zustand/idb-store.d.ts"
      ],
      "postgres/queue": [
        "dist/postgres/queue.d.ts"
      ]
    }
  },
  "dependencies": {
    "fast-json-stable-stringify": "^2.1.0",
    "idb": "^8.0.0",
    "idb-keyval": "^6.2.1",
    "sql-template-tag": "^5.0.0",
    "lodash": "^4.17.21",
    "uuid": "^14.0.0",
    "zod": "^3.22.4",
    "zustand": "^5.0.3"
  },
  "peerDependencies": {
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.1.1",
    "@types/lodash": "^4.17.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.2",
    "pg": "^8.13.0",
    "prettier": "^3.4.2",
    "rolldown": "1.0.3",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": false
  }
}
